setopt PROMPT_SUBST

# Set the zsh prompt based on if we are root or a regular user
if [ "$EUID" = 0 ] || [ "$(whoami)" = 'root' ]; then
    PS1='%F{yellow}[%~]%f
%B%F{red}%n@%m%f%F{yellow}#%f%b '
else
    # Slim PS1 — context lives in the tmux status bar
    hostn=$(/usr/bin/uname -n)
    if [[ "${hostn}" == "kevin" ]]; then
        host_color="208"   # orange (256-color)
    else
        host_color="cyan"
    fi

    PS1='%B%F{cyan}%n@%f%B%F{'"${host_color}"'}%m%f%F{yellow}>%f%b '
fi
