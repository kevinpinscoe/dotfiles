# Work environments
if [[ -r "$HOME/.homebrew/gh-token" ]]; then
  IFS= read -r HOMEBREW_GITHUB_API_TOKEN < "$HOME/.homebrew/gh-token"
  export HOMEBREW_GITHUB_API_TOKEN
fi

# Add Homebrew to PATH
eval "$(/opt/homebrew/bin/brew shellenv)"
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"

# Add dotnet tools
dotnet_roots=(/opt/homebrew/Cellar/dotnet/*/libexec)
if [ -d "${dotnet_roots[-1]}" ]; then
    export DOTNET_ROOT="${dotnet_roots[-1]}"
fi
unset dotnet_roots
export PATH="$PATH:$HOME/.dotnet/tools"

# Finish PATH
export PATH=$PATH:/System/Cryptexes/App/usr/bin

# Docker
source ~/.docker/init-bash.sh || true # Added by Docker Desktop

# mesactl
[[ -f $HOME/.environment/mesactl-bash-completion-script.sh ]] && source $HOME/.environment/mesactl-bash-completion-script.sh
