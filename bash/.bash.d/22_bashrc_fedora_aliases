# ~/.bash.d/22_bashrc_fedora_aliases

# Only apply on Fedora systems
if [ ! -f /etc/fedora-release ]; then
    return
fi

# Launch Obsidian Personal Journal vault
alias journal='~/AppImages/Obsidian.AppImage "obsidian://open?vault=Personal%20Journal" &>/dev/null &'

# Log in to self-hosted Gitea container registry
alias dlogin='cat ~/.config/gitea/api | docker login git.kevininscoe.com --username kevin --password-stdin'
