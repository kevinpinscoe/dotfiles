# Work environments

# gitme search roots (Mac): scan home directory only
export GITME_DIRS="$HOME"

if [[ -r "$HOME/.homebrew/gh-token" ]]; then
  IFS= read -r HOMEBREW_GITHUB_API_TOKEN < "$HOME/.homebrew/gh-token"
  export HOMEBREW_GITHUB_API_TOKEN
fi

# Add Homebrew to PATH
eval "$(/opt/homebrew/bin/brew shellenv)"
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"

# Cargo (Rust) bin — for tools installed via `cargo install` (e.g. jit-cli)
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH"

# binutils (keg-only): exposes greadelf/readelf and friends.
# Note: this also shadows system `as`, `ld`, `ar`, `ranlib`. If a build
# breaks unexpectedly, suspect this and bypass with absolute paths.
[[ -d /opt/homebrew/opt/binutils/bin ]] && export PATH="/opt/homebrew/opt/binutils/bin:$PATH"

# Add dotnet tools. Use `find` instead of a shell glob: zsh errors on unmatched
# globs (errexit on NO_NOMATCH) before the subshell's stderr redirect can help.
if [ -d /opt/homebrew/Cellar/dotnet ]; then
    latest_dotnet=$(find /opt/homebrew/Cellar/dotnet -mindepth 2 -maxdepth 2 -type d -name libexec 2>/dev/null | sort | tail -n 1)
    if [ -n "$latest_dotnet" ]; then
        export DOTNET_ROOT="$latest_dotnet"
    fi
    unset latest_dotnet
fi
export PATH="$PATH:$HOME/.dotnet/tools"

# Finish PATH
export PATH=$PATH:/System/Cryptexes/App/usr/bin

# Docker
source ~/.docker/init-bash.sh || true # Added by Docker Desktop

# mesactl (bash completion script — only source in bash; it uses `type -t`
# and `complete`, which are not portable to zsh)
if [ -n "$BASH_VERSION" ] && [ -f "$HOME/.environment/mesactl-bash-completion-script.sh" ]; then
    source "$HOME/.environment/mesactl-bash-completion-script.sh"
fi
